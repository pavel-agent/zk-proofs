{
  "name": "zero-knowledge-proofs",
  "version": "1.0.0",
  "description": "A simplified zk-SNARK-style zero-knowledge proof system using BN128",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "zkp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --loader ts-node/esm src/cli.ts",
    "prove": "node --loader ts-node/esm src/cli.ts prove",
    "verify": "node --loader ts-node/esm src/cli.ts verify",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["zero-knowledge", "zk-snark", "bn128", "cryptography"],
  "license": "MIT",
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@noble/curves": "^1.8.0"
  }
}
